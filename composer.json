{
  "name": "carloschininin/php-spreadsheet",
  "description": "Utilities for spreadsheet",
  "type": "library",
  "license": "proprietary",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "authors": [
    {
      "name": "Carlos Chininin",
      "email": "carloschininin@gmail.com"
    }
  ],
  "require": {
    "php": "^8.4",
    "ext-zip": "*",
    "openspout/openspout": "^5.6",
    "phpoffice/phpspreadsheet": "^5.4",
    "symfony/http-foundation": "^7.0|^8.0",
    "symfony/mime": "^7.0|^8.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^v3.70",
    "phpunit/phpunit": "^13.0"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "CarlosChininin\\Spreadsheet\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CarlosChininin\\Spreadsheet\\Tests\\": "tests/"
    }
  },
  "suggest": {
    "ext-xlswriter": "Extension required"
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit --testsuite Unit",
    "test:functional": "phpunit --testsuite Functional"
  }
}
